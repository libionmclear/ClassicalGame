{
  "private": true,
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "test:engine:ts": "node --import tsx --test test/engine.test.ts",
    "test:game:ts": "node --import tsx --test test/*.test.ts",
    "test:browser": "npm run build:web && node test/browser-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "build:engine": "tsc -p tsconfig.json",
    "simulate:italia": "node --import tsx src/simulate-italia.ts",
    "balance": "node --import tsx scripts/balance-sim.ts",
    "build:web": "node scripts/build-web.mjs",
    "slice-sprites": "node scripts/slice-sprites.mjs",
    "server": "node scripts/build-web.mjs && node --no-warnings=ExperimentalWarning server/hegemon-server.mjs",
    "serve:only": "node --no-warnings=ExperimentalWarning server/hegemon-server.mjs",
    "play:web": "npm run build:web",
    "vercel-build": "npm run build:web",
    "push:auto": "node scripts/publish-auto.mjs",
    "optimize-models": "node scripts/optimize-models.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "esbuild": "^0.25.8",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@types/three": "^0.185.0",
    "three": "^0.185.1"
  }
}
