# 3D models: the OPTIMIZED glbs (≤~1 MB, via scripts/optimize-models) ARE committed so
# every build/deploy has them. Only RAW multi-MB exports stay out — put those under
# assets/models/_raw/ (gitignored) and optimize into assets/models/units|cities/.
assets/models/_raw/

# Raw art uploads (huge Meshy/Midjourney exports) — promoted into assets/approved via npm run import-assets
assets/raw/

# asset refresh state / provenance (local)
assets/.asset-scan.json
assets/.asset-provenance.log

# local dev screenshot scripts (hold test creds)
_shot.mjs
_demoshot.mjs
_defshot.mjs
_propshot.mjs
